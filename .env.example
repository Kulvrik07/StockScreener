# API Keys – kopiere diese Datei zu ".env" und trage deine Keys ein
# Finnhub: kostenloser Account auf https://finnhub.io/
FINNHUB_API_KEY=your_finnhub_api_key_here

# Alpha Vantage: kostenloser Account auf https://www.alphavantage.co/
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# NewsAPI: kostenloser Account auf https://newsapi.org/ (nur Entwicklung)
NEWS_API_KEY=your_newsapi_key_here
